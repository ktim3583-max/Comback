-- --- LOGIC NÚT MỚI: SHOOT MURDER (TP + REMOTE BẮN BỤNG) ---
btn_ShootMurderTP.MouseButton1Click:Connect(function()
    local murder = nil
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) then
            murder = p
            break
        end
    end

    if murder and murder.Character and murder.Character:FindFirstChild("HumanoidRootPart") then
        local gun = char:FindFirstChild("Gun") or lp.Backpack:FindFirstChild("Gun")
        
        if hrp and gun then
            if gun.Parent == lp.Backpack then
                gun.Parent = char
                task.wait(0.1)
            end

            -- Dịch chuyển ra sau lưng Murder 3 Studs
            hrp.CFrame = murder.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) 
            task.wait(0.1)

            -- Tìm vị trí bụng (UpperTorso / Torso)
            local mudBelly = murder.Character:FindFirstChild("UpperTorso") or murder.Character:FindFirstChild("Torso") or murder.Character.HumanoidRootPart
            local gunTip = gun:FindFirstChild("Handle") or hrp
            
            -- Đóng gói dữ liệu Remote SimpleSpy gửi lên Server
            local args = {
                [1] = gunTip.CFrame,
                [2] = mudBelly.CFrame
            }

            gun.Shoot:FireServer(unpack(args))
        else
            warn("Bạn không có súng hoặc súng chưa sẵn sàng!")
        end
    else
        warn("Không tìm thấy Murder trong phòng!")
    end
end)

