-- --- AUTO GRAB GUN ---
local function GetDroppedGun()
    local Names = {"GunDrop", "DropGun", "Gundrop", "gundrop", "Dropgun", "dropgun"}
    for _, name in pairs(Names) do
        local gun = workspace:FindFirstChild(name, true)
        if gun and (gun:IsA("Model") or gun:IsA("BasePart")) then return gun end
    end
    return nil
end

btn_GrabMode.MouseButton1Click:Connect(function()
    if GrabMode == "Bring" then
        GrabMode = "Teleport"
        btn_GrabMode.Text = "Mode: TP"
        btn_GrabMode.BackgroundColor3 = Color3.fromRGB(200, 50, 0)
    else
        GrabMode = "Bring"
        btn_GrabMode.Text = "Mode: Bring"
        btn_GrabMode.BackgroundColor3 = Color3.fromRGB(150, 0, 200)
    end
end)

task.spawn(function()
    while ScriptRunning do
        task.wait()
        if AutoGrabActive and char and hrp and hrp.Parent then
            local gun = GetDroppedGun()
            if gun then
                local gunPart = gun:IsA("Model") and (gun:FindFirstChildWhichIsA("BasePart", true) or gun.PrimaryPart) or gun
                if gunPart then
                    if GrabMode == "Bring" then
                        gunPart.CFrame = hrp.CFrame
                    elseif GrabMode == "Teleport" then
                        local OldCFrame = hrp.CFrame
                        hrp.CFrame = gunPart.CFrame
                        task.wait(0.1)
                        hrp.CFrame = OldCFrame
                        task.wait(0.5)
                    end
                end
            end
        end
    end
end)

