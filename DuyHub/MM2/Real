end)

-- --- ESP PLAYER & ESP GUN ---
local function CleanESP()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("MM2_TotalESP") then p.Character.MM2_TotalESP:Destroy() end
    end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BillboardGui") and v.Name == "MM2_GunESP" then v:Destroy() end
    end
end

btn_Esp.MouseButton1Click:Connect(function()
    EspActive = not EspActive
    espInd.BackgroundColor3 = EspActive and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    
    if EspActive then
        task.spawn(function()
            while EspActive and ScriptRunning do
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local hl = p.Character:FindFirstChild("MM2_TotalESP")
                        if not hl then
                            hl = Instance.new("Highlight")
                            hl.Name = "MM2_TotalESP"
                            hl.FillTransparency = 0.5
                            hl.Parent = p.Character
                        end
                        if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                            hl.FillColor = Color3.fromRGB(255, 0, 0)
                        elseif p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then
                            hl.FillColor = Color3.fromRGB(0, 0, 255)
                        else
                            hl.FillColor = Color3.fromRGB(0, 255, 0)
                        end
                    end
                end

                local gun = GetDroppedGun()
                if gun then
                    local gunPart = gun:IsA("Model") and (gun:FindFirstChildWhichIsA("BasePart", true) or gun.PrimaryPart) or gun
                    if gunPart and not gunPart:FindFirstChild("MM2_GunESP") then
                        local bbgui = Instance.new("BillboardGui")
                        bbgui.Name = "MM2_GunESP"
                        bbgui.AlwaysOnTop = true
                        bbgui.Size = UDim2.new(0, 50, 0, 20)
                        bbgui.StudsOffset = Vector3.new(0, 2, 0)
                        bbgui.Parent = gunPart

                        local label = Instance.new("TextLabel")
                        label.Size = UDim2.new(1, 0, 1, 0)
                        label.BackgroundTransparency = 1
                        label.Text = "GUN"
                        label.TextColor3 = Color3.fromRGB(255, 255, 0)
                        label.TextSize = 14
                        label.Font = Enum.Font.SourceSansBold
                        label.Parent = bbgui
                    end
                end
                task.wait(0.5)
            end
        end)
    else
        CleanESP()
    end
end)

-- --- X-RAY MAP ---
btn_Xray.MouseButton1Click:Connect(function()
    XrayActive = not XrayActive
    xrayInd.BackgroundColor3 = XrayActive and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    if XrayActive then
        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and not obj:IsDescendantOf(game.Players) then
                OriginalTransparencies[obj] = obj.Transparency
                obj.Transparency = 0.3
            end
        end
    else
        for obj, trans in pairs(OriginalTransparencies) do if obj and obj.Parent then obj.Transparency = trans end end
        OriginalTransparencies = {}
    end
end)

-- --- LẬP TRÌNH FLING BÁM ĐUÔI XOAY VÒNG ---
btn_Fling.MouseButton1Click:Connect(function()
    Flinging = not Flinging
    TargetName = string.lower(txt_FlingName.Text)
    
    if Flinging and hrp and hrp.Parent then
        local target = nil
        if TargetName ~= "" then
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= lp and (string.find(string.lower(v.Name), TargetName) or string.find(string.lower(v.DisplayName), TargetName)) then 
                    target = v 
                    break 
                end
            end
        end
        
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            btn_Fling.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            
            local BV = hrp:FindFirstChild("FlingForce") or Instance.new("BodyAngularVelocity", hrp)
            BV.Name = "FlingForce"
            BV.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            BV.AngularVelocity = Vector3.new(9000, 9000, 9000)
            
            task.spawn(function()
                while Flinging and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and hrp and hrp.Parent and ScriptRunning do
                    RunService.Heartbeat:wait()
                    hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 1, -0.2)
                    hrp.Velocity = Vector3.new(999, 999, 999)
                end
                Flinging = false
                btn_Fling.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
                if BV and BV.Parent then BV:Destroy() end
            end)
        else 
            Flinging = false 
            btn_Fling.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
        end
    else
        Flinging = false
        btn_Fling.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
        if hrp and hrp:FindFirstChild("FlingForce") then hrp.FlingForce:Destroy() end
    end
end)

