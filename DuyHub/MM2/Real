local function CreateButton(text)
    local btn = Instance.new("TextButton", Scroll)
    btn.BorderSizePixel = 0
    btn.TextSize = 10
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    btn.FontFace = Font.new([[rbxasset://fonts/families/PressStart2P.json]], Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    btn.Size = UDim2.new(0, 204, 0, 34)
    btn.Text = text
    Instance.new("UICorner", btn)
    return btn
end

local function CreateToggle(text)
    local tog = Instance.new("TextButton", Scroll)
    tog.BorderSizePixel = 0
    tog.TextXAlignment = Enum.TextXAlignment.Left
    tog.TextSize = 9
    tog.TextColor3 = Color3.fromRGB(255, 255, 255)
    tog.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    tog.FontFace = Font.new([[rbxasset://fonts/families/PressStart2P.json]], Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    tog.Size = UDim2.new(0, 204, 0, 34)
    tog.Text = " " .. text
    Instance.new("UICorner", tog)

    local indicator = Instance.new("Frame", tog)
    indicator.BorderSizePixel = 0
    indicator.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    indicator.Size = UDim2.new(0, 24, 0, 24)
    indicator.Position = UDim2.new(1, -30, 0, 5)
    Instance.new("UICorner", indicator)

    return tog, indicator
end

