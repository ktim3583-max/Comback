-- [[ LOGIC CHECK KEY & CHẠY SCRIPT MỚI ]] --

local CorrectKey = "Vinysoua_key123"

CheckBtn.MouseButton1Click:Connect(function()
    -- Hàm xóa bỏ khoảng trắng thừa ở đầu/cuối chuỗi để tránh lỗi gõ phím trên điện thoại
    local userInput = KeyInput.Text:match("^%s*(.-)%s*$")
    
    if userInput == CorrectKey then
        CheckBtn.Text = "SUCCESS!"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        task.wait(0.5)
        
        -- Xóa GUI hoàn toàn trước khi chạy script mới
        ScreenGui:Destroy()
        
        -- Thực thi Link Real mới của mày (Có bọc pcall chống crash và có dấu () kích hoạt)
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ktim3583-max/Comback/refs/heads/main/DuyHub/MM2/Real"))()
        end)
        
        if not success then
            warn("Lỗi loadstring: " .. tostring(err))
        end
    else
        -- Báo sai key
        CheckBtn.Text = "WRONG KEY!"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        task.wait(1)
        CheckBtn.Text = "CHECK KEY"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
end)
