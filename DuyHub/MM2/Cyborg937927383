-- --- XỬ LÝ ESP DẠNG VIỀN TỔNG HỢP ---
LMG2L["TextButton_3"].MouseButton1Click:Connect(function()
    EspActive = not EspActive
    if EspActive then
        LMG2L["TextButton_3"].BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        task.spawn(function()
            while EspActive do
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local highlight = p.Character:FindFirstChild("MM2_TotalESP")
                        if not highlight then
                            highlight = Instance.new("Highlight")
                            highlight.Name = "MM2_TotalESP"
                            highlight.OutlineColor = Color3.new(1, 1, 1)
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            highlight.Parent = p.Character
                        end

                        if p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife") then
                            highlight.FillColor = Color3.fromRGB(255, 0, 0)     -- Murderer: Đỏ
                        elseif p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun") then
                            highlight.FillColor = Color3.fromRGB(0, 0, 255)     -- Sheriff: Xanh lam
                        else
                            highlight.FillColor = Color3.fromRGB(0, 255, 0)     -- Innocent: Xanh lá
                        end
                    end
                end
                task.wait(1)
            end
        end)
    else
        LMG2L["TextButton_3"].BackgroundColor3 = Color3.fromRGB(104, 0, 255)
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character then
                local hl = p.Character:FindFirstChild("MM2_TotalESP")
                if hl then hl:Destroy() end
            end
        end
    end
end)

-- --- XỬ LÝ X-RAY (ĐỘ MỜ MAP 0.3) ---
LMG2L["TextButton_4"].MouseButton1Click:Connect(function()
    XrayActive = not XrayActive
    if XrayActive then
        LMG2L["TextButton_4"].BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and not obj:IsDescendantOf(game.Players) then
                OriginalTransparencies[obj] = obj.Transparency
                obj.Transparency = 0.3
            end
        end
    else
        LMG2L["TextButton_4"].BackgroundColor3 = Color3.fromRGB(104, 0, 255)
        for obj, trans in pairs(OriginalTransparencies) do
            if obj and obj.Parent then
                obj.Transparency = trans
            end
        end
        OriginalTransparencies = {}
    end
end)

-- --- XỬ LÝ KHÓA MỤC TIÊU THEO TÊN ---
LMG2L["TextBox_6"].FocusLost:Connect(function()
    TargetName = string.lower(LMG2L["TextBox_6"].Text)
end)

local function GetClosestPlayer()
    if TargetName == "" then return nil end
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= lp and (string.find(string.lower(v.Name), TargetName) or string.find(string.lower(v.DisplayName), TargetName)) then
            return v
        end
    end
    return nil
end

-- --- XỬ LÝ NÚT FLING PHYSICS GỐC (BÁM ĐẦU XOAY TỐC ĐỘ BÀN THỜ) ---
LMG2L["TextButton_7"].MouseButton1Click:Connect(function()
    Flinging = not Flinging
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if Flinging and hrp then
        local target = GetClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            LMG2L["TextButton_7"].BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Đổi đỏ báo hiệu đang chạy
            
            -- Khởi tạo lực xoay vật lý cực mạnh để tạo lực đẩy
            local BV = Instance.new("BodyAngularVelocity", hrp)
            BV.Name = "FlingForce"
            BV.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            BV.AngularVelocity = Vector3.new(6000, 6000, 6000)
            
            -- Tắt va chạm tạm thời để không bị kẹt góc vật lý
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
            
            task.spawn(function()
                while Flinging and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") do
                    task.wait()
                    local targetHrp = target.Character.HumanoidRootPart
                    -- Đè CFrame bám sát đầu đối phương và ép vận tốc đẩy bật văng đi
                    hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 1.4, -0.1)
                    hrp.Velocity = Vector3.new(888, 888, 888)
                end
                
                -- Dọn dẹp dứt điểm khi tắt hoặc mất mục tiêu
                if BV then BV:Destroy() end
                LMG2L["TextButton_7"].BackgroundColor3 = Color3.fromRGB(104, 0, 255)
                for _, p in pairs(char:GetChildren()) do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end)
        else
            Flinging = false
        end
    else
        Flinging = false
        local force = hrp and hrp:FindFirstChild("FlingForce")
        if force then force:Destroy() end
        if char then
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") then p.CanCollide = true end
            end
        end
    end
end)

-- --- QUÉT VÀ NHẶT SÚNG RƠI ---
local function GetDroppedGun()
    local Names = {"GunDrop", "DropGun", "Gundrop", "gundrop", "Dropgun", "dropgun"}
    for _, name in pairs(Names) do
        local gun = game.Workspace:FindFirstChild(name, true)
        if gun and (gun:IsA("Model") or gun:IsA("BasePart")) then return gun end
    end
    return nil
end

LMG2L["TextButton_5"].MouseButton1Click:Connect(function()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local gun = GetDroppedGun()
    if gun then
        local OldCFrame = hrp.CFrame
        local TargetCFrame = gun:IsA("Model") and gun:GetPivot() or gun.CFrame
        hrp.CFrame = TargetCFrame
        task.wait(0.1)
        hrp.CFrame = OldCFrame
    end
end)

