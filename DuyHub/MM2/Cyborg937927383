btn_TPInno.MouseButton1Click:Connect(function()
    local innos = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if not (p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")) and not (p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")) then
                table.insert(innos, p)
            end
        end
    end
    if #innos > 0 then
        local randomInno = innos[math.random(1, #innos)]
        lp.Character.HumanoidRootPart.CFrame = randomInno.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
    end
end)

