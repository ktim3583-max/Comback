-- [[ THÔNG BÁO HỆ THỐNG SETCORE - VINYSOUA SCRIPT ]] --

local StarterGui = game:GetService("StarterGui")

-- Tạo BindableFunction để xử lý hành động khi bấm nút
local Bindable = Instance.new("BindableFunction")

-- Định nghĩa hành động khi người dùng bấm vào các nút lựa chọn
Bindable.OnInvoke = function(ButtonPressed)
    if ButtonPressed == "Run" then
        -- Kích hoạt loadstring link Real của mày nếu chọn Run
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ktim3583-max/Comback/refs/heads/main/DuyHub/MM2/Real"))()
        end)
        
        if not success then
            warn("Lỗi loadstring: " .. tostring(err))
        end
    elseif ButtonPressed == "No" then
        -- Nếu chọn No thì không làm gì cả, thông báo tự tắt
        print("Người dùng đã hủy kích hoạt script.")
    end
end

-- Gửi thông báo SetCore chuẩn của Roblox lên góc màn hình
local success, err = pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "Vinysoua script",
        Text = "Do you want to run this script?",
        Duration = 15, -- Thông báo sẽ hiển thị trong 15 giây nếu không bấm
        Callback = Bindable, -- Gắn hành động xử lý nút bấm vào đây
        Button1 = "Run", -- Nút thứ nhất
        Button2 = "No"   -- Nút thứ hai
    })
end)

-- Đề phòng trường hợp Delta chưa load xong StarterGui khi vừa vào game
if not success then
    task.wait(1)
    StarterGui:SetCore("SendNotification", {
        Title = "Vinysoua script",
        Text = "Do you want to run this script?",
        Duration = 15,
        Callback = Bindable,
        Button1 = "Run",
        Button2 = "No"
    })
end
