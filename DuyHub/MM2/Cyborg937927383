-- [[ XỬ LÝ LOGIC CHECK KEY ]] --

local CorrectKey = "36 thanh hóa + 67"

CheckBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CorrectKey then
        CheckBtn.Text = "SUCCESS!"
        CheckBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Đổi sang màu xanh khi đúng
        task.wait(1)
        
        -- Xóa GUI Key
        ScreenGui:Destroy()
        
        -- Chạy loadstring MM2 DuyHub của mày
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/ktim3583-max/Comback/refs/heads/main/DuyHub/MM2/Real"))()
        end)
        
        if not success then
            warn("Lỗi khi load script chính: ", err)
        end
    else
        -- Xử lý khi sai key
        CheckBtn.Text = "WRONG KEY!"
        task.wait(1.5)
        CheckBtn.Text = "CHECK KEY"
    end
end)
