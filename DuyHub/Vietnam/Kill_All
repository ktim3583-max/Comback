local toggled = false

Toggle.MouseButton1Click:Connect(function()
    toggled = not toggled

    Toggle.Text = toggled and "On" or "Off"
    Toggle.BackgroundColor3 = toggled and Color3.fromRGB(0,170,0) or Color3.fromRGB(255,0,0)

    if toggled then
        task.spawn(function()
            while toggled do
                local targets = {}

                for _,p in pairs(Players:GetPlayers()) do
                    if p ~= lp and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                        table.insert(targets,p.Character)
                    end
                end

                if #targets > 0 then
                    local target = targets[math.random(1,#targets)]

                    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    local targetHrp = target:FindFirstChild("HumanoidRootPart")
                    local head = target:FindFirstChild("Head")

                    if hrp and targetHrp and head then
                        local pos = head.Position + (targetHrp.CFrame.LookVector * 0.5) + Vector3.new(0,1.5,0)

                        hrp.CFrame = CFrame.lookAt(pos, head.Position)
                    end
                end

                task.wait(0.1)
            end
        end)
    end
end)

local collapsed = false

Minimize.MouseButton1Click:Connect(function()
    collapsed = not collapsed

    Frame:TweenSize(
        collapsed and UDim2.new(0,134,0,22) or UDim2.new(0,134,0,98),
        "Out",
        "Quad",
        0.2,
        true
    )

    Minimize.Text = collapsed and "+" or "-"
end)
