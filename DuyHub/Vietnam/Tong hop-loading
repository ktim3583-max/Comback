-- CHỮ % (TRÊN THANH BAR)
local PercentText = Instance.new("TextLabel", MainFrame)
PercentText.Size = UDim2.new(1, 0, 0, 20)
PercentText.Position = UDim2.new(0, 0, 0, 65)
PercentText.BackgroundTransparency = 1
PercentText.Text = "0%"
PercentText.TextColor3 = Color3.new(1, 1, 1)
PercentText.Font = Enum.Font.GothamSemibold
PercentText.TextSize = 14

-- THANH TIẾN TRÌNH (BACKGROUND BAR)
local BarBG = Instance.new("Frame", MainFrame)
BarBG.Size = UDim2.new(0.8, 0, 0, 10)
BarBG.Position = UDim2.new(0.1, 0, 0, 90)
BarBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
BarBG.BackgroundTransparency = 0.3
Instance.new("UICorner", BarBG)

-- THANH TIẾN TRÌNH (FILLING BAR)
local BarFill = Instance.new("Frame", BarBG)
BarFill.Size = UDim2.new(0, 0, 1, 0)
BarFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
Instance.new("UICorner", BarFill)

-- CHỮ TRẠNG THÁI (DƯỚI THANH BAR)
local StatusText = Instance.new("TextLabel", MainFrame)
StatusText.Size = UDim2.new(1, 0, 0, 30)
StatusText.Position = UDim2.new(0, 0, 0, 110)
StatusText.BackgroundTransparency = 1
StatusText.Text = "Đang khởi tạo..."
StatusText.TextColor3 = Color3.new(1, 1, 1)
StatusText.Font = Enum.Font.Gotham
StatusText.TextSize = 13

-- // LOGIC ANIMATION & LOADING
local function StartLoading()
    -- 1. Animation trượt lên
    MainFrame:TweenPosition(UDim2.new(0.5, -175, 0.5, -90), "Out", "Back", 0.8, true)
    task.wait(1)

    local currentPercent = 0
    
    -- Vòng lặp loading 20s
    for i = 1, 100 do
        currentPercent = i
        
        -- Cập nhật Text % và Thanh Bar
        PercentText.Text = currentPercent .. "%"
        TweenService:Create(BarFill, TweenInfo.new(0.1), {Size = UDim2.new(currentPercent/100, 0, 1, 0)}):Play()
        
        -- Cập nhật nội dung chữ "h"
        if currentPercent <= 30 then
            StatusText.Text = "Đang tải dữ liệu (" .. currentPercent .. "%)"
        elseif currentPercent <= 65 then
            StatusText.Text = "Đang bật anti cheat (" .. currentPercent .. "%)"
        elseif currentPercent <= 85 then
            StatusText.Text = "Đang tải gui chính (" .. currentPercent .. "%)"
        elseif currentPercent <= 98 then
            StatusText.Text = "Sắp hoàn tất (" .. currentPercent .. "%)"
        else
            StatusText.Text = "Hoàn tất ✅"
        end

        -- Logic khựng mỗi 10%
        if i % 10 == 0 then
            task.wait(0.5) -- Khựng lại 0.5 giây
        else
            task.wait(0.15) -- Tốc độ bình thường (tổng cộng ~20s)
        end
    end

    task.wait(1)
    
    -- 2. Animation trượt xuống khi biến mất
    MainFrame:TweenPosition(UDim2.new(0.5, -175, 1.2, 0), "In", "Back", 0.8, true)
    
    task.wait(0.8)
    ScreenGui:Destroy()
task.wait(0)
loadstring(game:HttpGet("https://raw.githubusercontent.com/ktim3583-max/Comback/refs/heads/main/DuyHub/Vietnam/Tong%20hop))();
end

-- Chạy Loading
task.spawn(StartLoading)
