local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

-- // XÓA UI CŨ NẾU CÓ
if CoreGui:FindFirstChild("DuyXD_Loading") then CoreGui.DuyXD_Loading:Destroy() end

-- // TẠO SCREEN GUI
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "DuyXD_Loading"

-- // KHUNG CHÍNH (MAIN FRAME)
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 350, 0, 180)
MainFrame.Position = UDim2.new(0.5, -175, 1.2, 0) -- Bắt đầu ở dưới màn hình để trượt lên
MainFrame.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
MainFrame.BackgroundTransparency = 0.5
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể kéo thả

local MainCorner = Instance.new("UICorner", MainFrame)
MainCorner.CornerRadius = UDim.new(0, 15)

-- CHỮ LOADING
local LoadingText = Instance.new("TextLabel", MainFrame)
LoadingText.Size = UDim2.new(1, 0, 0, 40)
LoadingText.Position = UDim2.new(0, 0, 0, 10)
LoadingText.BackgroundTransparency = 1
LoadingText.Text = "LOADING"
LoadingText.TextColor3 = Color3.new(1, 1, 1)
LoadingText.Font = Enum.Font.GothamBold
