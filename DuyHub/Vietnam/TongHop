local function AddScript(tabName, btnName, code)
    local btn = Instance.new("TextButton")
    btn.Parent = ContentHolder
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Text = btnName
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 14
    btn.Visible = false
    btn:SetAttribute("Tab", tabName)
    local bCorner = Instance.new("UICorner"); bCorner.Parent = btn
    btn.MouseButton1Click:Connect(function() pcall(function() loadstring(code)() end) end)
end

-- [[ HÀM CHUYỂN TAB ]]
local function ShowTab(name)
    for _, obj in pairs(ContentHolder:GetChildren()) do
        if obj:IsA("TextButton") then
            obj.Visible = (obj:GetAttribute("Tab") == name)
        end
    end
end

local function CreateTabBtn(name)
    local tBtn = Instance.new("TextButton")
    tBtn.Parent = TabHolder
    tBtn.Size = UDim2.new(0.9, 0, 0, 40)
    tBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    tBtn.Text = name
    tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    tBtn.Font = Enum.Font.GothamBold
    tBtn.TextSize = 13
    local tc = Instance.new("UICorner"); tc.Parent = tBtn
    tBtn.MouseButton1Click:Connect(function() ShowTab(name) end)
end

