-- [[ LOGIC KILL ALL MM2 ]]
local KillAllActive = false
local originalPositions = {}
local function resetPositions()
    for p, oldCFrame in pairs(originalPositions) do
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.CFrame = oldCFrame
        end
    end
    originalPositions = {}
end

RunService.RenderStepped:Connect(function()
    if KillAllActive then
        local char = lp.Character
        local holdsKnife = char and (char:FindFirstChild("Knife") or char:FindFirstChild("Weapon"))
        if holdsKnife and char:FindFirstChild("HumanoidRootPart") then
            local root = char.HumanoidRootPart
            local targetPos = root.CFrame * CFrame.new(0, 0, -0.8)
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if not originalPositions[p] then originalPositions[p] = p.Character.HumanoidRootPart.CFrame end
                    p.Character.HumanoidRootPart.CFrame = targetPos
                end
            end
        end
    else
        if next(originalPositions) ~= nil then resetPositions() end
    end
end)

-- [[ HÀM TẠO NÚT SCRIPT ]]
local function AddScript(tabName, btnName, code, isToggle)
    local btn = Instance.new("TextButton")
    btn.Parent = ContentHolder
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Text = btnName
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = MCFont
    btn.TextSize = 14
    btn.Visible = false
    btn:SetAttribute("Tab", tabName)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    
    btn.MouseButton1Click:Connect(function() 
        if isToggle then
            KillAllActive = not KillAllActive
            btn.Text = "KILL ALL: " .. (KillAllActive and "ON" or "OFF")
            btn.BackgroundColor3 = KillAllActive and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(60, 60, 60)
        else
            pcall(function() loadstring(code)() end)
        end
    end)
end

local function ShowTab(name)
    for _, obj in pairs(ContentHolder:GetChildren()) do
        if obj:IsA("TextButton") then obj.Visible = (obj:GetAttribute("Tab") == name) end
    end
end

local function CreateTabBtn(name)
    local tBtn = Instance.new("TextButton")
    tBtn.Parent = TabHolder
    tBtn.Size = UDim2.new(0.9, 0, 0, 35)
    tBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    tBtn.Text = name
    tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    tBtn.Font = MCFont
    tBtn.TextSize = 13
    Instance.new("UICorner", tBtn).CornerRadius = UDim.new(0, 4)
    tBtn.MouseButton1Click:Connect(function() ShowTab(name) end)
end

