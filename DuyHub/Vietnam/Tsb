local function boostFPS()
    -- Xóa shadow + lighting
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    lighting.Brightness = 0
    lighting.ClockTime = 14
    lighting:ClearAllChildren()

