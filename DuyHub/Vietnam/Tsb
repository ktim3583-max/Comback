local Tab5 = Window:CreateTab("Teleport", 4483362458)
Tab5:CreateSection("📍 Teleport Player")

local targetName = ""

Tab5:CreateInput({
   Name = "Nhập tên player",
   PlaceholderText = "vd: duy",
   Callback = function(text)
      targetName = string.lower(text)
   end,
})

local function findPlayer(name)
   for _,plr in pairs(Players:GetPlayers()) do
      if string.find(string.lower(plr.Name), name) then
         return plr
      end
   end
end

Tab5:CreateButton({
   Name = "Teleport",
   Callback = function()
      local lp = Players.LocalPlayer
      local char = lp.Character or lp.CharacterAdded:Wait()
      local hrp = char:WaitForChild("HumanoidRootPart")

      local target = findPlayer(targetName)
      if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
         hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3)
      end
   end,
})
