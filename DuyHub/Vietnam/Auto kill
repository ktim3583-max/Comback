-- ================= AUTO KILL =================
local enabled = false
local mode = "under"
local orbitAngle = 0
local orbitDistance = 5

local function getNearest()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local nearest, dist = nil, math.huge
    for _,v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local d = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist = d
                nearest = v
            end
        end
    end
    return nearest
end

toggleBtn.MouseButton1Click:Connect(function()
    enabled = not enabled
    toggleBtn.Text = "⚔ Auto Kill: " .. (enabled and "ON" or "OFF")
end)

modeBtn.MouseButton1Click:Connect(function()
    mode = (mode == "under") and "orbit" or "under"
    modeBtn.Text = "🌀 Mode: " .. string.upper(mode)
end)

RS.Heartbeat:Connect(function(dt)
    if not enabled then return end

    local char = player.Character
    local target = getNearest()

    if char and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local targetHRP = target.Character.HumanoidRootPart

        if mode == "under" then
            hrp.CFrame = targetHRP.CFrame * CFrame.new(0,-3,0)
            hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0,1,0))

        elseif mode == "orbit" then
            orbitAngle += dt * 18.5
            local x = math.cos(orbitAngle) * orbitDistance
            local z = math.sin(orbitAngle) * orbitDistance
            hrp.CFrame = targetHRP.CFrame * CFrame.new(x,0,z)
        end
    end
end)

