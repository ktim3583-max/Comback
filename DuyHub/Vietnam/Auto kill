-- ================= FREECAM MOBILE =================
local freecam = false
local camCF
local camSpeed = 3
local moveVec = Vector3.new()
local dragging = false

-- joystick
local joy = Instance.new("Frame", gui)
joy.Size = UDim2.new(0,100,0,100)
joy.Position = UDim2.new(0,20,1,-120)
joy.BackgroundColor3 = Color3.fromRGB(40,40,40)
joy.BackgroundTransparency = 0.3
Instance.new("UICorner", joy)

local knob = Instance.new("Frame", joy)
knob.Size = UDim2.new(0,40,0,40)
knob.Position = UDim2.new(0.3,0,0.3,0)
knob.BackgroundColor3 = Color3.fromRGB(0,255,200)
Instance.new("UICorner", knob)

knob.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch then dragging = true end
end)

knob.InputEnded:Connect(function()
    dragging = false
    moveVec = Vector3.new()
    knob.Position = UDim2.new(0.3,0,0.3,0)
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = (input.Position - joy.AbsolutePosition) - joy.AbsoluteSize/2
        local x = math.clamp(delta.X/40, -1, 1)
        local y = math.clamp(delta.Y/40, -1, 1)

        moveVec = Vector3.new(x,0,y)
        knob.Position = UDim2.new(0.3 + x*0.3,0,0.3 + y*0.3,0)
    end
end)

UIS.TouchMoved:Connect(function(input)
    if freecam then
        local cam = workspace.CurrentCamera
        camCF = camCF * CFrame.Angles(0, -input.Delta.X*0.002, 0)
    end
end)

freecamBtn.MouseButton1Click:Connect(function()
    freecam = not freecam
    freecamBtn.Text = "👻 Free Cam: " .. (freecam and "ON" or "OFF")

    local cam = workspace.CurrentCamera
    if freecam then
        cam.CameraType = Enum.CameraType.Scriptable
        camCF = cam.CFrame
    else
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            cam.CameraType = Enum.CameraType.Custom
            cam.CameraSubject = char.Humanoid
        end
    end
end)

RS.RenderStepped:Connect(function()
    if not freecam then return end

    local cam = workspace.CurrentCamera
    local forward = cam.CFrame.LookVector * -moveVec.Z
    local right = cam.CFrame.RightVector * moveVec.X

    camCF = camCF + (forward + right) * camSpeed
    cam.CFrame = camCF
end)
