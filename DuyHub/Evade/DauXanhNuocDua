local UserInputService = game:GetService("UserInputService")
local Frame = LMG2L["Frame_2"]
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)


local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer

local infiniteSlideEnabled = false
local bhopEnabled = false
local slideFrictionValue = -16
local cachedTables = nil
local plrModel = nil
local slideConnection = nil
local bhopConnection = nil

local slideKeys = {
    "Friction","AirStrafeAcceleration","JumpHeight","RunDeaccel",
    "JumpSpeedMultiplier","JumpCap","SprintCap","WalkSpeedMultiplier",
    "BhopEnabled","Speed","AirAcceleration","RunAccel","SprintAcceleration"
}

local function hasAll(tbl)
    if type(tbl) ~= "table" then return false end
    for _, k in ipairs(slideKeys) do
        if rawget(tbl, k) == nil then return false end
    end
    return true
end

local function refreshVapeTables()
    cachedTables = {}
    for _, obj in ipairs(getgc(true)) do
        local success, result = pcall(function()
            if type(obj) == "table" and hasAll(obj) then 
                return obj 
            end
        end)
        if success and result then 
            table.insert(cachedTables, result) 
        end
    end
end

local function setFriction(value)
    if not cachedTables then return end
    for _, t in ipairs(cachedTables) do
        pcall(function() t.Friction = value end)
    end
end

local function setBhopState(state)
    if not cachedTables then return end
    for _, t in ipairs(cachedTables) do
        pcall(function() t.BhopEnabled = state end)
    end
end

local function updatePlayerModel()
    local GameFolder = Workspace:FindFirstChild("Game")
    local PlayersFolder = GameFolder and GameFolder:FindFirstChild("Players")
    if PlayersFolder then
        plrModel = PlayersFolder:FindFirstChild(player.Name)
    else
        plrModel = nil
    end
end


local function onSlideHeartbeat()
    if not plrModel then
        setFriction(5) 
        return
    end
    
    local success, currentState = pcall(function()
        return plrModel:GetAttribute("State")
    end)
    
    if success and currentState then
        if currentState == "Slide" then
            pcall(function()
                plrModel:SetAttribute("State", "EmotingSlide")
            end)
        elseif currentState == "EmotingSlide" then
            setFriction(slideFrictionValue)
        else
            setFriction(5) 
        end
    else
        setFriction(5)
    end
end


local function onBhopHeartbeat()
    if bhopEnabled then
        setBhopState(true)
        if cachedTables then
            for _, t in ipairs(cachedTables) do
                pcall(function()
                    if t.JumpCap then t.JumpCap = 0 end
                end)
            end
        end
    end
end


local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if method == "FireServer" and self.Name == "Emote" then
        local eName = args[1]
        if infiniteSlideEnabled and eName then
            task.spawn(function()
                task.wait(0.1)
                local success, emoteModule = pcall(function()
                    return require(game:GetService("ReplicatedStorage").Items.Emotes[eName])
                end)
                if success and emoteModule and emoteModule.EmoteInfo then
                    if slideFrictionValue then
                        setFriction(slideFrictionValue)
                    end
                end
            end)
        end
    end
    return oldNamecall(self, ...)
end)


player.CharacterAdded:Connect(function()
    task.wait(0.5) 
    updatePlayerModel()
    
    if infiniteSlideEnabled or bhopEnabled then
        refreshVapeTables()
    end
end)


local SlideButton = LMG2L["TextButton_6"]

SlideButton.MouseButton1Click:Connect(function()
    infiniteSlideEnabled = not infiniteSlideEnabled
    
    if infiniteSlideEnabled then
        SlideButton.Text = "Infinite slide : On"
        SlideButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        
        refreshVapeTables()
        updatePlayerModel()
        
        if slideConnection then slideConnection:Disconnect() end
        slideConnection = RunService.Heartbeat:Connect(onSlideHeartbeat)
    else
        SlideButton.Text = "Infinite slide : Off"
        SlideButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        
        if slideConnection then 
            slideConnection:Disconnect() 
            slideConnection = nil 
        end
        setFriction(5) 
    end
end)


