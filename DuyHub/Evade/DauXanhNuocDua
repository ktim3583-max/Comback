-- 10.4 Revive Interaction Handler
ReviveButton.MouseButton1Click:Connect(function()
    Logger.Log("Attempting character revival protocol...")
    local TargetEvent = ReplicatedStorage:FindFirstChild("Events")
    if TargetEvent then
        local PlayerEventFolder = TargetEvent:FindFirstChild("Player")
        if PlayerEventFolder then
            local ChangeModeRemote = PlayerEventFolder:FindFirstChild("ChangePlayerMode")
            if ChangeModeRemote then
                local FireSuccess, FireError = pcall(function()
                    ChangeModeRemote:FireServer(true)
                end)
                if FireSuccess then
                    Logger.Log("Revival remote invoked successfully.")
                else
                    Logger.Warn("Remote invocation faulted: " .. tostring(FireError))
                end
            else
                Logger.Warn("ChangePlayerMode instance missing.")
            end
        else
            Logger.Warn("Player folder within Events missing.")
        end
    else
        Logger.Warn("Events directory not found in ReplicatedStorage.")
    end
end)

