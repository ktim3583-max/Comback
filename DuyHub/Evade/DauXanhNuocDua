    local SlideCondition = GlobalSettings.Status.SlideActive
    local BhopCondition = GlobalSettings.Status.BhopActive
    
    if SlideCondition or BhopCondition then
        for TableIndex = 1, #GarbageCollectorTables do
            local CurrentTargetTable = GarbageCollectorTables[TableIndex]
            
            if SlideCondition then
                pcall(function()
                    CurrentTargetTable.Friction = GlobalSettings.Engine.Friction
                end)
            end
            
            if BhopCondition then
                pcall(function()
                    CurrentTargetTable.BhopEnabled = true
                end)
            end
        end
    end
    
    if BhopCondition then
        local CurrentCharacter = LocalPlayer.Character
        if CurrentCharacter then
            local TargetHumanoid = CurrentCharacter:FindFirstChildOfClass("Humanoid")
            if TargetHumanoid then
                if TargetHumanoid.FloorMaterial ~= Enum.Material.Air then
                    pcall(function()
                        TargetHumanoid.Jump = true
                    end)
                end
            end
        end
    end
end)

