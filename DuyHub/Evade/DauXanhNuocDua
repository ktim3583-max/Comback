-- // SECTION 9: MEMORY SCANNER FUNCTION (VAPE CORE ENGINE)
local function PerformMemoryScan()
    GarbageCollectorTables = {}
    local ExecutionSuccess, RawGC = pcall(function()
        return getgc(true)
    end)
    
    if not ExecutionSuccess or not RawGC then
        Logger.Warn("Failed to execute getgc invocation.")
        return
    end
    
    for Index = 1, #RawGC do
        local ScannedObject = RawGC[Index]
        if type(ScannedObject) == "table" then
            local HasFriction = rawget(ScannedObject, "Friction") ~= nil
            local HasAirAccel = rawget(ScannedObject, "AirStrafeAcceleration") ~= nil
            
            if HasFriction and HasAirAccel then
                table.insert(GarbageCollectorTables, ScannedObject)
            end
        end
    end
    Logger.Log("Scan complete. Elements cached: " .. tostring(#GarbageCollectorTables))
end

